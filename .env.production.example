# Sage With You — production build (.env.production is loaded by Vite for `npm run build`)
# Copy to ".env.production" on the machine that builds for GoDaddy deploy.

VITE_SUPABASE_URL=https://htckswutkpktxclyijwk.supabase.co
VITE_SUPABASE_ANON_KEY=paste_anon_public_key_here

VITE_SITE_URL=https://sagewithyou.org

