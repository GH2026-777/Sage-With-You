# VITE_ENABLE_PASSWORD_GATE=false
VITE_STAGING_GATE_PASSWORD=your_staging_password_here

# Optional library Storage (after migration 003 + uploads):
# VITE_LIBRARY_USE_STORAGE=true

# Optional analytics (loads only after cookie consent):
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
